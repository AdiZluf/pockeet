{
  "expo": {
    "name": "Pockeet",
    "slug": "pockeet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/pockeet-icon.png",
    "scheme": "pockeet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/pockeet-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pockeet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F5F2"
      },
      "package": "com.pockeet.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-sqlite",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Pockeet to access your camera to scan receipts.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Pockeet to access your photos to upload receipt images.",
          "microphonePermission": false,
          "cameraPermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
